# =============================================================================
# Pulsar Configuration
# =============================================================================
# Copy this file to .env and update the values as needed.
# Never commit your .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings (PUBLIC - safe to expose to client)
# -----------------------------------------------------------------------------
APP_NAME=Pulsar
APP_URL=http://localhost:5173
APP_DEBUG=false                   # Set to true for development
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
NODE_ENV=development              # development, production, test
PORT=3000

# -----------------------------------------------------------------------------
# Feature Flags (PUBLIC - safe to expose to client)
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Application Secrets (PRIVATE - server-only)
# -----------------------------------------------------------------------------
APP_KEY=                          # Generate: openssl rand -base64 32
SESSION_SECRET=                   # Generate: openssl rand -base64 32

# -----------------------------------------------------------------------------
# Database Settings (PRIVATE - server-only)
# -----------------------------------------------------------------------------
# PostgreSQL (recommended for production)
DATABASE_URL="postgresql://user:password@localhost:5432/pulsar?schema=public"

# For local SQLite development, use:
# DATABASE_URL="file:./prisma/data/pulsar.db"

PRISMA_LOG_LEVEL=warn            # query, info, warn, error
PRISMA_LOG_QUERIES=false

# -----------------------------------------------------------------------------
# Blockchain/Crypto Services (PRIVATE - server-only)
# -----------------------------------------------------------------------------
# CoinGecko API (for price data)
# COINGECKO_API_KEY=
# COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Etherscan API (for Ethereum data)
# ETHERSCAN_API_KEY=
# ETHERSCAN_BASE_URL=https://api.etherscan.io/api

# Alchemy (Ethereum RPC provider)
# ALCHEMY_API_KEY=
# ALCHEMY_NETWORK=mainnet

# Infura (Ethereum RPC provider)
# INFURA_PROJECT_ID=
# INFURA_PROJECT_SECRET=

# -----------------------------------------------------------------------------
# Encryption (PRIVATE - server-only)
# -----------------------------------------------------------------------------
# Used to encrypt SimpleFIN Access URLs stored in DB
ENCRYPTION_SECRET=                # Generate: openssl rand -hex 32

# -----------------------------------------------------------------------------
# IBKR Flex Web Service (PRIVATE - server-only)
# -----------------------------------------------------------------------------
# For fetching Interactive Brokers portfolio holdings
# Set up in IBKR Client Portal → Reporting → Flex Queries → Flex Web Service
# IBKR_FLEX_TOKEN=                # Current Token from Flex Web Service config
# IBKR_FLEX_QUERY_ID=             # Query ID from your Activity Flex Query
